---
// src/pages/portfolio/projects/[slug].astro
// Purpose: Project summary page — scope, data, approach, outcome + linked notebooks
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TagBadge from '../../../components/TagBadge.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
const {
  title, summary, tags, techStack, sector, scope, data, approach, outcome,
  keyFindings, notebookProject,
} = project.data;

// Get related notebooks
const allNotebooks = await getCollection('notebooks');
const notebooks = allNotebooks
  .filter(nb => nb.data.project === notebookProject)
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title={title} description={summary}>
  <article class="py-16 md:py-24 max-w-4xl mx-auto px-6">
    <a href="/portfolio" class="text-sm text-brand-electric hover:underline mb-6 inline-block">&larr; Back to Portfolio</a>

    <!-- Header -->
    <div class="mb-10">
      <div class="flex gap-2 flex-wrap mb-4">
        {tags.map(tag => <TagBadge tag={tag} />)}
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-brand-navy dark:text-white mb-4">{title}</h1>
      <p class="text-lg text-slate-500 dark:text-slate-400 mb-4">{summary}</p>
      <div class="flex gap-2 flex-wrap">
        {techStack.map(tech => (
          <span class="text-xs font-mono bg-slate-100 dark:bg-slate-800 px-2 py-1 rounded">{tech}</span>
        ))}
      </div>
    </div>

    <!-- Key Findings -->
    {keyFindings.length > 0 && (
      <div class="bg-brand-amber/10 border border-brand-amber/30 rounded-lg p-6 mb-10">
        <h2 class="text-lg font-semibold text-brand-navy dark:text-white mb-3">Key Findings</h2>
        <ul class="space-y-2">
          {keyFindings.map(finding => (
            <li class="text-sm text-slate-600 dark:text-slate-300 flex gap-2">
              <span class="text-brand-amber mt-0.5 shrink-0">&#9679;</span>
              <span>{finding}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Project Details Grid -->
    <div class="grid gap-8 md:grid-cols-2 mb-12">
      <div class="rounded-xl border border-slate-200 dark:border-slate-700 p-6">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-electric mb-3">Scope</h2>
        <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed">{scope}</p>
      </div>

      <div class="rounded-xl border border-slate-200 dark:border-slate-700 p-6">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-electric mb-3">Data</h2>
        <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed">{data}</p>
      </div>

      <div class="rounded-xl border border-slate-200 dark:border-slate-700 p-6">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-electric mb-3">Analytical Approach</h2>
        <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed">{approach}</p>
      </div>

      <div class="rounded-xl border border-slate-200 dark:border-slate-700 p-6">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-brand-electric mb-3">Outcome</h2>
        <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed">{outcome}</p>
      </div>
    </div>

    <!-- Markdown body content -->
    <div class="prose dark:prose-invert max-w-none mb-10">
      <Content />
    </div>

    <!-- Linked Notebooks -->
    {notebooks.length > 0 && (
      <div class="mt-10">
        <h2 class="text-2xl font-bold text-brand-navy dark:text-white mb-6">Notebooks</h2>
        <ol class="space-y-3">
          {notebooks.map(nb => (
            <li>
              <a
                href={`/portfolio/${nb.slug}/`}
                class="flex items-start gap-4 p-4 rounded-xl border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors"
              >
                <span class="text-brand-amber font-mono text-sm mt-0.5 shrink-0">
                  {String(nb.data.order).padStart(2, '0')}
                </span>
                <div class="flex-1 min-w-0">
                  <span class="font-medium text-brand-navy dark:text-white">
                    {nb.data.title.replace(/^\d+\s*—\s*/, '')}
                  </span>
                  <p class="text-sm text-slate-500 mt-1">{nb.data.summary}</p>
                  <div class="flex gap-1.5 flex-wrap mt-2">
                    {nb.data.techStack.slice(0, 5).map(tech => (
                      <span class="text-xs font-mono bg-slate-100 dark:bg-slate-800 px-1.5 py-0.5 rounded">{tech}</span>
                    ))}
                  </div>
                </div>
                <svg class="w-5 h-5 text-slate-400 mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </li>
          ))}
        </ol>
      </div>
    )}
  </article>
</BaseLayout>
