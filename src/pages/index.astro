---
// src/pages/index.astro
// Purpose: Home page — Hero, value prop, featured work, latest content, CTA
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TagBadge from '../components/TagBadge.astro';
import { getCollection } from 'astro:content';

// Fetch content for home page sections
const projects = await getCollection('projects');
const posts = await getCollection('blog');
const notes = await getCollection('notes');

// Sort and limit
const recentPosts = posts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const recentNotes = notes
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const categoryLabel: Record<string, string> = {
  insight: 'Insight',
  highlight: 'Project Highlight',
  news: 'News',
};

const categoryColor: Record<string, string> = {
  insight: 'bg-brand-electric/10 text-brand-electric',
  highlight: 'bg-brand-amber/10 text-brand-amber',
  news: 'bg-emerald-500/10 text-emerald-600',
};
---
<BaseLayout title="Home" description="Industrial energy analytics portfolio and blog by Abriliam Consulting.">
  <Hero />

  <!-- Value Proposition -->
  <section class="py-16 md:py-20 border-t border-slate-200 dark:border-slate-800">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-brand-navy dark:text-white mb-8">What We Do</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="rounded-xl border border-slate-200 dark:border-slate-700 p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-electric/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-electric" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
            </svg>
          </div>
          <h3 class="font-semibold text-brand-navy dark:text-white mb-2">Plant Performance Analytics</h3>
          <p class="text-sm text-slate-500">Chiller plant diagnostics, refrigeration system optimization, and equipment performance analysis using operational trend data and thermodynamic modeling.</p>
        </div>
        <div class="rounded-xl border border-slate-200 dark:border-slate-700 p-6">
          <div class="w-10 h-10 rounded-lg bg-brand-amber/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-amber" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <h3 class="font-semibold text-brand-navy dark:text-white mb-2">Savings Estimation & M&V</h3>
          <p class="text-sm text-slate-500">Prospective energy savings analysis and post-implementation measurement & verification aligned with IPMVP for retrofit justification and incentive applications.</p>
        </div>
        <div class="rounded-xl border border-slate-200 dark:border-slate-700 p-6">
          <div class="w-10 h-10 rounded-lg bg-emerald-500/10 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-semibold text-brand-navy dark:text-white mb-2">Electricity Cost Optimization</h3>
          <p class="text-sm text-slate-500">ML-driven peak demand prediction, Global Adjustment optimization for Ontario Class A customers, and load curtailment strategy development.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Work -->
  <section class="py-16 md:py-20 bg-slate-50 dark:bg-slate-900/50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-brand-navy dark:text-white">Featured Work</h2>
        <a href="/portfolio" class="text-sm text-brand-electric hover:underline">View all &rarr;</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {projects.map((proj) => (
          <a href={`/portfolio/projects/${proj.slug}/`} class="group block rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 overflow-hidden hover:border-brand-electric/50 transition-colors">
            <div class="p-6">
              <div class="flex gap-2 flex-wrap mb-3">
                {proj.data.tags.slice(0, 3).map(tag => <TagBadge tag={tag} />)}
              </div>
              <h3 class="font-bold text-brand-navy dark:text-white mb-2 group-hover:text-brand-electric transition-colors">
                {proj.data.title}
              </h3>
              <p class="text-sm text-slate-500 mb-4">{proj.data.summary}</p>
              <div class="flex gap-1.5 flex-wrap">
                {proj.data.techStack.slice(0, 4).map(tech => (
                  <span class="text-xs font-mono bg-slate-100 dark:bg-slate-700 px-1.5 py-0.5 rounded">{tech}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Blog Posts -->
  <section class="py-16 md:py-20 bg-slate-50 dark:bg-slate-900/50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-brand-navy dark:text-white">Latest from the Blog</h2>
        <a href="/blog" class="text-sm text-brand-electric hover:underline">All posts &rarr;</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.slug}/`} class="group block rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 hover:border-brand-electric/50 transition-colors">
            <div class="flex gap-2 flex-wrap mb-3">
              {post.data.tags.slice(0, 2).map(tag => <TagBadge tag={tag} />)}
            </div>
            <h3 class="font-bold text-brand-navy dark:text-white mb-2 group-hover:text-brand-electric transition-colors text-sm leading-snug">
              {post.data.title}
            </h3>
            <p class="text-xs text-slate-500 line-clamp-2">{post.data.summary}</p>
            <time datetime={post.data.date} class="block text-xs text-slate-400 mt-3">
              {new Date(post.data.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Notes -->
  {recentNotes.length > 0 && (
    <section class="py-16 md:py-20">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-brand-navy dark:text-white">Notes & Highlights</h2>
          <a href="/notes" class="text-sm text-brand-electric hover:underline">All notes &rarr;</a>
        </div>
        <div class="space-y-4">
          {recentNotes.map((note) => (
            <a href={`/notes/${note.slug}/`} class="group block rounded-lg border border-slate-200 dark:border-slate-700 p-4 hover:border-brand-electric/50 transition-colors">
              <div class="flex items-start gap-4">
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-1">
                    <span class={`text-xs font-semibold px-2 py-0.5 rounded-full ${categoryColor[note.data.category]}`}>
                      {categoryLabel[note.data.category]}
                    </span>
                    <time datetime={note.data.date} class="text-xs text-slate-400">
                      {new Date(note.data.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                  </div>
                  <h3 class="font-semibold text-brand-navy dark:text-white group-hover:text-brand-electric transition-colors text-sm">
                    {note.data.title}
                  </h3>
                  <p class="text-xs text-slate-500 mt-1">{note.data.summary}</p>
                </div>
                <svg class="w-4 h-4 text-slate-300 dark:text-slate-600 shrink-0 mt-1 group-hover:text-brand-electric transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-brand-navy dark:bg-slate-900">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Have a project that needs analysis?</h2>
      <p class="text-slate-300 mb-8 max-w-xl mx-auto">
        We work with industrial and commercial facilities across Ontario on energy cost reduction, system optimization, and data-driven decision making.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/contact" class="btn-primary">Get in Touch</a>
        <a href="/portfolio" class="inline-block border border-slate-500 text-white font-semibold px-6 py-3 rounded-lg hover:border-brand-electric hover:text-brand-electric transition-colors">
          View Our Work
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
