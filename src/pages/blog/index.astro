---
// src/pages/blog/index.astro
// Purpose: Blog listing page — list of posts with tags and reading time
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

// Sort by date descending
const sortedPosts = posts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Estimate reading time (~200 words per minute)
function readingTime(body: string): string {
  const words = body.trim().split(/\s+/).length;
  const minutes = Math.max(1, Math.round(words / 200));
  return `${minutes} min read`;
}
---
<BaseLayout title="Blog" description="Articles on energy analytics, case studies, and tutorials.">
  <section class="py-16 md:py-24 max-w-5xl mx-auto px-6">
    <h1 class="text-4xl font-bold tracking-tight text-brand-navy dark:text-white mb-4">Blog</h1>
    <p class="text-slate-500 mb-12 max-w-2xl">
      Case studies, opinion pieces, and tutorials on industrial energy management, data analytics, and building performance.
    </p>

    {sortedPosts.length === 0 ? (
      <p class="text-slate-500">No posts yet. Check back soon.</p>
    ) : (
      <div class="space-y-8">
        {sortedPosts.map((post) => (
          <article class="group rounded-xl border border-slate-200 dark:border-slate-700 p-6 md:p-8 hover:border-brand-electric/50 transition-colors">
            <a href={`/blog/${post.slug}/`} class="block">
              <div class="flex gap-2 flex-wrap mb-3">
                {post.data.tags.map(tag => <TagBadge tag={tag} />)}
              </div>
              <h2 class="text-xl font-bold text-brand-navy dark:text-white mb-2 group-hover:text-brand-electric transition-colors">
                {post.data.title}
              </h2>
              <p class="text-slate-500 mb-3">{post.data.summary}</p>
              <div class="flex items-center gap-4 text-sm text-slate-400">
                <time datetime={post.data.date}>
                  {new Date(post.data.date).toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span>{readingTime(post.body || '')}</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
