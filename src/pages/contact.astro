---
// src/pages/contact.astro
// Purpose: Contact form using Formspree
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact" description="Get in touch with Abriliam Consulting for energy analytics and consulting engagements.">
  <section class="py-16 md:py-24 max-w-4xl mx-auto px-6">

    <h1 class="text-4xl font-bold tracking-tight text-brand-navy dark:text-white mb-4">Get in Touch</h1>
    <p class="text-slate-500 mb-12 max-w-2xl">
      Have a project in mind, a dataset that needs analysis, or a question about our work? We'd like to hear from you.
    </p>

    <div class="grid md:grid-cols-5 gap-12">

      <!-- Form -->
      <div class="md:col-span-3">
        <form
          action="https://formspree.io/f/xzaborvl"
          method="POST"
          class="space-y-6"
        >
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-brand-electric focus:border-transparent outline-none transition-colors"
              placeholder="Your name"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-brand-electric focus:border-transparent outline-none transition-colors"
              placeholder="you@example.com"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Subject</label>
            <select
              id="subject"
              name="subject"
              class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-brand-electric focus:border-transparent outline-none transition-colors"
            >
              <option value="general">General Inquiry</option>
              <option value="project">Project Engagement</option>
              <option value="notebook">Question About a Notebook / Analysis</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Message</label>
            <textarea
              id="message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-3 rounded-lg border border-slate-300 dark:border-slate-600 bg-white dark:bg-slate-800 text-slate-900 dark:text-white focus:ring-2 focus:ring-brand-electric focus:border-transparent outline-none transition-colors resize-y"
              placeholder="Tell us about your project or question..."
            ></textarea>
          </div>

          <!-- Honeypot -->
          <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

          <button
            type="submit"
            class="bg-brand-electric text-white font-semibold px-8 py-3 rounded-lg hover:opacity-90 transition-opacity"
          >
            Send Message
          </button>
        </form>
      </div>

      <!-- Sidebar -->
      <div class="md:col-span-2 space-y-8">
        <div>
          <h3 class="font-semibold text-brand-navy dark:text-white mb-2">Email</h3>
          <a href="mailto:info@abriliamconsulting.com" class="text-brand-electric hover:underline text-sm">
            info@abriliamconsulting.com
          </a>
        </div>

        <div>
          <h3 class="font-semibold text-brand-navy dark:text-white mb-2">Location</h3>
          <p class="text-sm text-slate-500">Ontario, Canada</p>
        </div>

        <div>
          <h3 class="font-semibold text-brand-navy dark:text-white mb-2">Typical Engagements</h3>
          <ul class="text-sm text-slate-500 space-y-1.5">
            <li>Chiller plant performance diagnostics</li>
            <li>Refrigeration ECM savings estimation</li>
            <li>M&V framework development</li>
            <li>Peak demand prediction & GA optimization</li>
            <li>Portfolio-level building screening</li>
          </ul>
        </div>

        <div class="rounded-lg bg-slate-50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 p-4">
          <p class="text-xs text-slate-400">
            We typically respond within 1-2 business days. For urgent matters, please note so in your message.
          </p>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
